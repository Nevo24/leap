  "description": "Allows Leap Monitor to select terminal tabs by name",
  "version": "1.2.1",
  "publisher": "leap",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
